{
  "name": "code-shame",
  "version": "0.1.4",
  "description": "Local web dashboard for Fallow code analysis reports.",
  "main": "src/server.js",
  "bin": {
    "code-shame": "src/start.js"
  },
  "files": [
    "assets",
    "public",
    "src",
    "README.md"
  ],
  "scripts": {
    "dev": "node src/start.js",
    "test": "node --test test/*.test.js",
    "pack:dry": "npm pack --dry-run"
  },
  "keywords": [
    "fallow",
    "code-analysis",
    "code-shame",
    "dashboard",
    "maintainability",
    "dead-code"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/idesiatkova/code-shame.git"
  },
  "bugs": {
    "url": "https://github.com/idesiatkova/code-shame/issues"
  },
  "homepage": "https://github.com/idesiatkova/code-shame#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "fallow": "2.91.0",
    "lucide": "1.21.0"
  }
}
